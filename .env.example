# Copy this file to .env and fill in your own values.
# The whole pipeline runs fine with NO key set (offline template fallback),
# so this is optional while you're building/demoing.

# "groq" | "gemini" | "none"
LLM_PROVIDER=none

# Get a free key at https://console.groq.com (Groq) or https://ai.google.dev (Gemini)
LLM_API_KEY=
